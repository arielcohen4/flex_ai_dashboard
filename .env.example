# ============================================================
# Flex AI Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key — server-side only, never expose to the browser
SUPABASE_ADMIN=your-supabase-service-role-key

# ------------------------------------------------------------
# Flex API (Modal-backed serverless compute)
# ------------------------------------------------------------
NEXT_PUBLIC_FLEX_API_URL=https://api.getflex.ai

# ------------------------------------------------------------
# RunPod (job cancellation)
# ------------------------------------------------------------
RUNPOD_API_KEY=your-runpod-api-key

# ------------------------------------------------------------
# Storage — DigitalOcean Spaces (or any S3-compatible endpoint)
# ------------------------------------------------------------
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_ACCESS_KEY_ID=your-spaces-access-key-id
DO_SPACES_SECRET_ACCESS_KEY=your-spaces-secret-access-key

# ------------------------------------------------------------
# Billing — Lemon Squeezy
# ------------------------------------------------------------
LEMON_SQUEEZY_API_KEY=your-lemon-squeezy-api-key
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_VARIANT_ID=your-variant-id

# ------------------------------------------------------------
# Analytics — PostHog
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Affiliates — FirstPromoter
# ------------------------------------------------------------
FIRSTPROMOTER_API_KEY=your-firstpromoter-api-key
